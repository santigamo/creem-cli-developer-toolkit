{
  "name": "creem-cli-developer-toolkit",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev:integration": "cd examples/minimal-integration && ~/.bun/bin/bun run --hot src/index.ts",
    "typecheck": "pnpm --dir examples/minimal-integration exec tsc --noEmit",
    "workflow:checkout": "bash ./scripts/verify-checkout.sh",
    "workflow:debug": "bash ./scripts/debug-propagation.sh",
    "workflow:manage": "bash ./scripts/manage-products.sh"
  }
}

